#!/usr/bin/env python3
"""Verify generated RSS, sitemap, robots, and discovery metadata."""

from html.parser import HTMLParser
from pathlib import Path
import sys
import xml.etree.ElementTree as ET

ROOT = Path(__file__).resolve().parents[1]
DOCS = ROOT / "docs"
REQUIRED_PAGES = (
    "index.html",
    "iot/index.html",
    "iot/iot-gateway-rest/index.html",
    "projects/index.html",
)
REQUIRED_OG = ("og:title", "og:description", "og:url", "og:image")


class LinkParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.alternates = []
        self.canonical = False
        self.json_ld = False
        self.meta_names = set()
        self.meta_properties = set()

    def handle_starttag(self, tag, attrs):
        attrs = dict(attrs)
        if tag == "meta":
            if "name" in attrs:
                self.meta_names.add(attrs["name"])
            if "property" in attrs:
                self.meta_properties.add(attrs["property"])
        if tag == "link" and attrs.get("rel") == "alternate":
            self.alternates.append(attrs)
        if tag == "link" and attrs.get("rel") == "canonical":
            self.canonical = True
        if tag == "script" and attrs.get("type") == "application/ld+json":
            self.json_ld = True


def rss_items(path):
    root = ET.parse(path).getroot()
    if root.tag != "rss":
        raise ValueError(f"{path}: expected rss root, got {root.tag}")
    return root.findall("./channel/item")


def sitemap_urls(path):
    root = ET.parse(path).getroot()
    ns = {"sm": "http://www.sitemaps.org/schemas/sitemap/0.9"}
    return root.findall("sm:url", ns)


def main():
    errors = []

    feeds = {
        "index.xml": 1,
        "iot/index.xml": 1,
        "software/index.xml": 1,
        "notes/index.xml": 1,
    }
    for rel, minimum in feeds.items():
        path = DOCS / rel
        if not path.exists():
            errors.append(f"{rel}: missing RSS feed")
            continue
        try:
            count = len(rss_items(path))
            if count < minimum:
                errors.append(f"{rel}: expected at least {minimum} RSS items, found {count}")
        except Exception as exc:
            errors.append(str(exc))

    sitemap = DOCS / "sitemap.xml"
    if not sitemap.exists():
        errors.append("sitemap.xml: missing")
    else:
        try:
            if not sitemap.read_text(encoding="utf-8").startswith("<?xml"):
                errors.append("sitemap.xml: XML declaration must be first byte")
            if len(sitemap_urls(sitemap)) == 0:
                errors.append("sitemap.xml: no URLs found")
        except Exception as exc:
            errors.append(str(exc))

    robots = DOCS / "robots.txt"
    if not robots.exists():
        errors.append("robots.txt: missing")
    else:
        text = robots.read_text(encoding="utf-8")
        if "Sitemap: https://rustyeddy.com/sitemap.xml" not in text:
            errors.append("robots.txt: missing sitemap directive")

    for rel in REQUIRED_PAGES:
        path = DOCS / rel
        if not path.exists():
            errors.append(f"{rel}: missing generated page")
            continue
        html = path.read_text(encoding="utf-8")
        parser = LinkParser()
        parser.feed(html)

        for prop in REQUIRED_OG:
            if prop not in parser.meta_properties:
                errors.append(f"{rel}: missing property=\"{prop}\"")
        if "twitter:card" not in parser.meta_names:
            errors.append(f"{rel}: missing name=\"twitter:card\"")
        if not parser.canonical:
            errors.append(f"{rel}: missing rel=\"canonical\"")
        if not any(attrs.get("type") == "application/rss+xml" for attrs in parser.alternates):
            errors.append(f"{rel}: missing type=\"application/rss+xml\"")
        if not parser.json_ld:
            errors.append(f"{rel}: missing type=\"application/ld+json\"")
        for attrs in parser.alternates:
            if attrs.get("type") == "application/rss+xml":
                href = attrs.get("href", "")
                if href.endswith("/projects/index.xml"):
                    errors.append(f"{rel}: advertises empty projects RSS feed")

    if errors:
        print("\n".join(errors), file=sys.stderr)
        return 1

    print("discovery ok")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
